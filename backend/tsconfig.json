{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "types": ["node"]
  },
  "include": ["src", "index.ts", "seed.ts"],
  "exclude": ["node_modules", "dist"]
}
